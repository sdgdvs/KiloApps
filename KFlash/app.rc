#include <windows.h>

200 DIALOGEX 0, 0, 200, 150
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Add New Card"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Front Text:", -1, 10, 10, 50, 10
    EDITTEXT        201, 10, 25, 180, 40, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL
    LTEXT           "Back Text:", -1, 10, 70, 50, 10
    EDITTEXT        202, 10, 85, 180, 40, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL
    DEFPUSHBUTTON   "Add", 203, 90, 130, 45, 15
    PUSHBUTTON      "Cancel", 204, 145, 130, 45, 15
END
