    LTEXT           "Host:", -1, 135, 28, 40, 8
    EDITTEXT        1003, 175, 26, 115, 14, ES_AUTOHSCROLL
    LTEXT           "Port:", -1, 135, 46, 40, 8
    EDITTEXT        1004, 175, 44, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Type:", -1, 135, 64, 40, 8
    COMBOBOX        1005, 175, 62, 70, 50, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Save", 1006, 135, 90, 50, 14
    PUSHBUTTON      "New", 1007, 190, 90, 50, 14
