3000 DIALOGEX 0, 0, 180, 140
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Display Settings"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Font Size (px):", -1, 10, 12, 60, 8
    EDITTEXT        3001, 80, 10, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Blink Rate (ms):", -1, 10, 32, 60, 8
    EDITTEXT        3002, 80, 30, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Baud Rate:", -1, 10, 52, 60, 8
    COMBOBOX        3006, 80, 50, 70, 60, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Local Echo", 3003, 10, 70, 60, 10
    PUSHBUTTON      "Edit Palette Colors...", 3004, 10, 90, 75, 14
    PUSHBUTTON      "Reset Palette", 3005, 90, 90, 60, 14
    DEFPUSHBUTTON   "Save", 1, 30, 115, 50, 14
    PUSHBUTTON      "Cancel", 2, 100, 115, 50, 14
END

4000 DIALOGEX 0, 0, 260, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "KBBS Help / Quick Reference"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Features:\r\n\r\n- Dialing Directory: Save & quick-connect to BBSs\r\n- XMODEM/ZMODEM: File transfers (DL/UL)\r\n- ANSI Music: Plays ANSI-M music codes\r\n- Macros: Bind Alt+Key to string sequences\r\n- Display Settings: Adjust font size, blink, palette\r\n- Scrollback: View past terminal history\r\n- Copy/Paste: Select text and copy/paste\r\n- Custom Palette: Set custom 16-color PC colors\r\n- Session Capture: Save session text to file\r\n- Baud Rate Emulation: Simulate old modem speeds", -1, 10, 10, 240, 150
    DEFPUSHBUTTON   "OK", 1, 105, 175, 50, 14
END
