1 ICON "icon.ico"
#include <windows.h>

1000 DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Dialing Directory"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LISTBOX         1001, 5, 5, 120, 190, LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Name:", -1, 135, 10, 40, 8
    EDITTEXT        1002, 175, 8, 115, 14, ES_AUTOHSCROLL
    LTEXT           "Host:", -1, 135, 28, 40, 8
    EDITTEXT        1003, 175, 26, 115, 14, ES_AUTOHSCROLL
    LTEXT           "Port:", -1, 135, 46, 40, 8
    EDITTEXT        1004, 175, 44, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Type:", -1, 135, 64, 40, 8
    COMBOBOX        1005, 175, 62, 70, 50, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Save", 1006, 135, 90, 50, 14
    PUSHBUTTON      "New", 1007, 190, 90, 50, 14
    PUSHBUTTON      "Delete", 1008, 245, 90, 45, 14
    DEFPUSHBUTTON   "Connect", 1, 135, 175, 75, 16
    PUSHBUTTON      "Cancel", 2, 215, 175, 75, 16
END

2000 DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Macros (Alt + Key)"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LISTBOX         2001, 5, 5, 120, 190, LBS_NOTIFY | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Key (e.g. L):", -1, 135, 10, 50, 8
    EDITTEXT        2002, 190, 8, 20, 14, ES_AUTOHSCROLL | ES_UPPERCASE
    LTEXT           "Sequence (use \\r):", -1, 135, 28, 100, 8
    EDITTEXT        2003, 135, 40, 155, 60, ES_MULTILINE | ES_WANTRETURN | WS_VSCROLL
    PUSHBUTTON      "Save", 2006, 135, 110, 50, 14
    PUSHBUTTON      "New", 2007, 190, 110, 50, 14
    PUSHBUTTON      "Delete", 2008, 245, 110, 45, 14
    PUSHBUTTON      "Close", 2, 215, 175, 75, 16
END

3000 DIALOGEX 0, 0, 180, 140
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Display Settings"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Font Size (px):", -1, 10, 12, 60, 8
    EDITTEXT        3001, 80, 10, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Blink Rate (ms):", -1, 10, 32, 60, 8
    EDITTEXT        3002, 80, 30, 40, 14, ES_AUTOHSCROLL | ES_NUMBER
1 ICON "icon.ico"
#include <windows.h>

1000 DIALOGEX 0, 0, 300, 200
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
